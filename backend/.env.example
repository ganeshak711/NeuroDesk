# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas (must have Atlas Vector Search enabled on the cluster)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ai_workspace?retryWrites=true&w=majority

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# LLM provider (used for RAG answer generation + streaming)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-5

# CORS
CLIENT_ORIGIN=http://localhost:3000
